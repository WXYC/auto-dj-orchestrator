@wxyc:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}

# @wxyc/shared declares better-auth as an OPTIONAL peer (peerDependenciesMeta),
# which this type-only consumer never installs. GitHub Packages strips
# peerDependenciesMeta from its packument, so npm's resolver still treats
# better-auth as a hard peer and tries to auto-install it — pulling
# @tanstack/react-start -> vite >=7, which collides with vitest's vite 5.
# legacy-peer-deps skips peer auto-install so @wxyc/shared/auto-dj (pure types)
# resolves without better-auth in the tree.
legacy-peer-deps=true
