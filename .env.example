# auto-dj-orchestrator configuration.
# Copy to .env and fill in. All values validated by src/config.ts at boot.

# ── HTTP / WS server ───────────────────────────────────────────────────────
ORCHESTRATOR_PORT=8090
ORCHESTRATOR_PUBLIC_URL=http://localhost:8090
LOG_LEVEL=info
# Comma-separated origins allowed to call the virtual-switch API from a browser (dj-site).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# SENTRY_DSN=                       # optional; observability is a no-op if unset

# ── Arduino-facing management channel ──────────────────────────────────────
AUTO_DJ_KEY=changeme                # X-Auto-DJ-Key shared secret (WS upgrade + HTTP fallback)
DEVICE_OFFLINE_THRESHOLD_MS=60000   # heartbeat older than this => device offline
WS_PING_INTERVAL_MS=15000           # server->device ws ping cadence (dead if no pong in 10s)

# ── AzuraCast now-playing source ───────────────────────────────────────────
AZURACAST_WS_URL=wss://remote.wxyc.org/api/live/nowplaying/websocket
AZURACAST_HTTP_URL=https://remote.wxyc.org/api/nowplaying_static/main.json
AZURACAST_STATION_SHORTCODE=wxyc    # Centrifugo channel is station:<shortcode> (verify before prod)
AZURACAST_SAFETY_POLL_MS=60000      # safety-net HTTP poll cadence while the WS is connected
AZURACAST_FALLBACK_POLL_MS=20000    # HTTP poll cadence when the WS is unavailable

# ── Backend-Service (single flowsheet backend; mirrors to tubafrenzy) ───────
BACKEND_SERVICE_URL=http://localhost:8080
AUTH_SERVICE_URL=http://localhost:8082/auth
AUTH_TRUSTED_ORIGIN=http://localhost:8090   # sent as Origin: on auth calls; must be in BETTER_AUTH_TRUSTED_ORIGINS
AUTO_DJ_EMAIL=auto-dj@wxyc.org
AUTO_DJ_PASSWORD=changeme
AUTO_DJ_SHOW_NAME=Auto DJ
TOKEN_REFRESH_SKEW_MS=60000         # refresh the JWT this long before it expires

# ── dj-site JWT verification (mirror the Backend-Service auth env) ──────────
BETTER_AUTH_JWKS_URL=http://localhost:8082/auth/jwks
BETTER_AUTH_ISSUER=http://localhost:8082
BETTER_AUTH_AUDIENCE=http://localhost:8082

# ── Restart recovery ───────────────────────────────────────────────────────
STATE_STORE_PATH=./auto-dj-state.json
